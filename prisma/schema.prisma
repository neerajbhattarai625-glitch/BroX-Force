generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Product {
  id             String   @id @default(cuid())
  title          String
  price          String
  discountPrice  String?
  description    String   @db.Text
  category       String
  imageUrl       String
  sizes          String[]
  colors         String[]
  stock          Int      @default(0)
  status         String   @default("In Stock")
  isFeatured     Boolean  @default(false)
  
  cartItems      CartItem[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model CartItem {
  id            String  @id @default(cuid())
  productId     String
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity      Int     @default(1)
  selectedSize  String?
  selectedColor String?
  customSize    String?
  
  // Note: For anonymous users, you might track carts via session ID.
  sessionId     String?
}

model Voucher {
  id                 String    @id @default(cuid())
  code               String    @unique
  discountPercentage Int
  isUsed             Boolean   @default(false)
  isActive           Boolean   @default(true)
  expiryDate         DateTime?
  usageLimit         Int?
  usageCount         Int       @default(0)
  createdAt          DateTime  @default(now())
}

model Theme {
  id      Int     @id @default(1)
  hero    String
  body    String
  footer  String
  logo    String?
}

model Order {
  id               String      @id @default(cuid())
  createdAt        DateTime    @default(now())
  customerName     String
  customerPhone    String
  customerEmail    String
  customerLocation String
  subtotal         String
  discount         Int         @default(0)
  total            String
  status           String      @default("Pending")
  paymentStatus    String      @default("Unpaid")
  paymentMethod    String      @default("cod")
  paymentCurrency  String      @default("NPR")
  trackingNo       String?
  appliedVoucher   String?
  isStockReduced   Boolean     @default(false)
  
  items            OrderItem[]
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  title      String
  quantity   Int
  price      String
  size       String?
  color      String?
  customSize String?
}

model Customer {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  phone          String
  address        String
  totalSpent     Float    @default(0)
  isBlocked      Boolean  @default(false)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Analytics {
  id             Int      @id @default(1)
  uniqueVisitors Int      @default(0)
  totalPageHits  Int      @default(0)
  revenueNPR     Float    @default(0)
  revenueUSD     Float    @default(0)
  profitNPR      Float    @default(0)
  profitUSD      Float    @default(0)
}

model AdminConfig {
  id                    Int     @id @default(1)
  email                 String  @default("codevengers8848@gmail.com")
  orderEmail            String  @default("codevengers8848@gmail.com")
  contactEmail          String  @default("codevengers8848@gmail.com")
  passwordHash          String  @default("brox@admin2024")
  esewa                 Boolean @default(true)
  khalti                Boolean @default(true)
  stripe                Boolean @default(false)
  cod                   Boolean @default(true)
  paypal                Boolean @default(true)
  shippingCost          Float   @default(5)
  freeShippingThreshold Float   @default(100)
  exchangeRate          Float   @default(135)
}
